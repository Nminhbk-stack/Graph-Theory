#include <bits/stdc++.h>
using namespace std;

using ll = long long;
int n, m;
vector<int> adj[200007];
stack<int> st;
int visited[20005];

void nhap(){
    cin >> n >> m;
    while(m--){
        int x, y; cin >> x >> y;
        adj[x].push_back(y);
    }
    for(int i = 1; i <= n; i++){
        sort(adj[i].begin(), adj[i].end());
    }

}

void dfs(int u){
    visited[u] = 1;
    for(int x : adj[u]){
        if(!visited[x]){
            dfs(x);
        }
    }
    st.push(u);
}

int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    nhap();
    for(int i = 1; i <= n; i++){
        if(!visited[i]){
            dfs(i);
        }
    }

    while(!st.empty()){
        cout << st.top() << " ";
        st.pop();
    }

    return 0;
}
